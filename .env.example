# Google Chat 알림 (Incoming Webhook)
# · 한 명/한 방만: URL 하나만 넣기
# · 담당자 3명(웹훅 3개): 쉼표 또는 줄바꿈으로 이어서 넣기
#   예) GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/.../A,https://.../B,https://.../C
# 또는 여러 줄:
# GOOGLE_CHAT_WEBHOOK_URLS="https://chat.googleapis.com/.../A
# https://chat.googleapis.com/.../B"
GOOGLE_CHAT_WEBHOOK_URL=
# GOOGLE_CHAT_WEBHOOK_URLS=


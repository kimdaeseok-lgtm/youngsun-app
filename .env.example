# 구글 시트
GOOGLE_SHEETS_ID=
# 또는 스프레드시트 URL 전체
# GOOGLE_SHEETS_URL=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=
# GOOGLE_SHEETS_SHEET_NAME=

# Google Chat 알림 (Incoming Webhook)
# · 한 명/한 방만: URL 하나만 넣기
# · 담당자 3명(웹훅 3개): 쉼표 또는 줄바꿈으로 이어서 넣기
#   예) GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/.../A,https://.../B,https://.../C
# 또는 여러 줄:
# GOOGLE_CHAT_WEBHOOK_URLS="https://chat.googleapis.com/.../A
# https://chat.googleapis.com/.../B"
GOOGLE_CHAT_WEBHOOK_URL=
# GOOGLE_CHAT_WEBHOOK_URLS=

# Firebase (클라이언트 Storage) — public/FIREBASE_STORAGE.md 참고
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# 예: myproject.appspot.com (콘솔 → Storage 버킷 이름)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── 구글 로그인 (shimteo.org 계정만 허용) ──
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 클라이언트 ID(웹 애플리케이션)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 세션 쿠키 서명용 무작위 문자열(길고 비밀스럽게). 예: openssl rand -base64 32
AUTH_SECRET=
# 허용 도메인(기본 shimteo.org). 바꿀 일 없으면 비워두세요.
# ALLOWED_EMAIL_DOMAIN=shimteo.org

# (구버전) 비밀번호 로그인은 제거됨 — ADMIN_PASSWORD 불필요
# (구버전) 팀즈 알림은 제거됨 — MS_TEAMS_WEBHOOK_URL 불필요
